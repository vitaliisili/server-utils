# Image tag
DDNS_IMAGE_TAG=latest

# Container name
DDNS_CONTAINER_NAME=ddns-updater

# Web UI port (HTTP)
DDNS_PORT=8000

# Update period (5m, 10m, 1h, etc)
DDNS_PERIOD=5m

# Log level (info, debug, warn, error)
DDNS_LOG_LEVEL=info

# DNS provider (namecheap, cloudflare, godaddy, etc)
DDNS_PROVIDER=namecheap

# Full domain to keep updated (e.g. home.opendemo.online or sub.domain.com)
DDNS_DOMAIN=home.opendemo.online

# Provider password / API token / Dynamic DNS password
DDNS_PASSWORD=your-namecheap-ddns-password-here

# Timezone
TZ=Europe/Berlin