# ===== Infisical required secrets =====
# Generate strong values:
#   openssl rand -hex 32
#   openssl rand -base64 48
ENCRYPTION_KEY=CHANGE_ME_TO_LONG_RANDOM_VALUE
AUTH_SECRET=CHANGE_ME_TO_LONG_RANDOM_VALUE

# ===== Public URL of Infisical =====
# Direct access on port 3331:
SITE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:3331
# If behind reverse proxy:
# SITE_URL=https://secrets.yourdomain.tld

# ===== Postgres settings (used by DB + to build DB_CONNECTION_URI) =====
POSTGRES_USER=infisical
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=infisical
