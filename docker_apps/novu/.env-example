NOVU_IMAGE_TAG=latest
NOVU_API_PORT=3400
NOVU_WS_PORT=3402
NOVU_DASHBOARD_PORT=4400

# URLs (adjust to your domain)
NOVU_API_ROOT_URL=https://novu-api.example.com
NOVU_WS_URL=https://novu-ws.example.com
NOVU_DASHBOARD_URL=https://novu.example.com

# Secrets (MUST change before production)
JWT_SECRET=replace-me
STORE_ENCRYPTION_KEY=replace-me-must-be-32-chars-long
NOVU_SECRET_KEY=replace-me

# MongoDB
MONGO_USERNAME=novu
MONGO_PASSWORD=replace-me