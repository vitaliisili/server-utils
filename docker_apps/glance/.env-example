# Image tag
GLANCE_IMAGE_TAG=latest

# Container name
GLANCE_CONTAINER_NAME=glance

# Web UI port (host -> container 8080)
GLANCE_PORT=3410

# Absolute host path for the persistent config directory.
# IMPORTANT: must live OUTSIDE the deploy directory — Komodo wipes the deploy
# tree on each redeploy and would destroy a relative ./config bind mount.
# Create it before first start:  mkdir -p /opt/docker_data/glance/config
# Glance reads /app/config/glance.yml inside the container.
GLANCE_CONFIG_PATH=/opt/docker_data/glance/config