# Image version
NOVU_IMAGE_TAG=3.14.0

# Exposed ports (host:container mapping in docker-compose)
NOVU_API_PORT=3400
NOVU_WS_PORT=3402
NOVU_DASHBOARD_PORT=4400

# Secrets - MUST CHANGE BEFORE PRODUCTION
JWT_SECRET=replace-me
STORE_ENCRYPTION_KEY=replace-me-32-chars-exactly!!
NOVU_SECRET_KEY=replace-me
SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d

# General
NODE_ENV=production
IS_SELF_HOSTED=true

# MongoDB
MONGO_INITDB_ROOT_USERNAME=novu
MONGO_INITDB_ROOT_PASSWORD=replace-me
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=5
MONGO_AUTO_CREATE_INDEXES=true

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_SERVICE_PORT=6379

# Internal ports
API_PORT=3000
WS_PORT=3002

# URLs (adjust to your domain)
HOST_NAME=https://novu.example.com
API_ROOT_URL=https://novu-api.example.com
FRONT_BASE_URL=https://novu.example.com
VITE_API_HOSTNAME=https://novu-api.example.com
VITE_WEBSOCKET_HOSTNAME=https://novu-ws.example.com
VITE_LEGACY_DASHBOARD_URL=

# AWS/S3 (leave empty if not using S3 storage)
S3_LOCAL_STACK=
S3_BUCKET_NAME=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Feature flags
IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
IS_V2_ENABLED=true
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false

# Analytics (disabled by default)
SENTRY_DSN=
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=
NEW_RELIC_LICENSE_KEY=

# Worker
BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100