# Image tag
HOMEPAGE_IMAGE_TAG=latest

# Container name
HOMEPAGE_CONTAINER_NAME=homepage

# Web UI port (host -> container 3000)
HOMEPAGE_PORT=3310

# User/group IDs that own the host config directory
HOMEPAGE_PUID=1000
HOMEPAGE_PGID=1000

# Allowed Host header(s) — required since v1.0.
# Use "*" to disable the check, or a comma-separated list like:
#   home.example.com,192.168.1.10:3310
HOMEPAGE_ALLOWED_HOSTS=*

# Absolute host path for the persistent config directory.
# IMPORTANT: must live OUTSIDE the deploy directory — Komodo wipes the deploy
# tree on each redeploy and would destroy a relative ./config bind mount.
# Create it before first start:  mkdir -p /opt/docker_data/homepage/config
HOMEPAGE_CONFIG_PATH=/opt/docker_data/homepage/config