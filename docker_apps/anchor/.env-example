# Image tag (use "next" for pre-release, "latest" for stable)
ANCHOR_IMAGE_TAG=latest

# Container and volume names
ANCHOR_CONTAINER_NAME=anchor
ANCHOR_VOLUME_NAME=anchor-data

# Web UI port (host -> container 3000)
ANCHOR_PORT=3510

# Public base URL of the Anchor instance.
# Set this to the externally-reachable URL when behind a reverse proxy.
ANCHOR_APP_URL=http://localhost:3510

# JWT secret for signing auth tokens. Leave empty to let Anchor auto-generate
# one on first start (stored in the data volume). Override for a fixed secret.
ANCHOR_JWT_SECRET=

# Signup policy: disabled | enabled | review
# Defaults to "disabled" here so a public deployment doesn't accept open signups.
ANCHOR_USER_SIGNUP=disabled