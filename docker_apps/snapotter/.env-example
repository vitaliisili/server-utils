SNAPOTTER_IMAGE_TAG=latest
SNAPOTTER_PORT=1349
CONTAINER_NAME=snapotter

# Authentication
AUTH_ENABLED=true
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=replace-me

# Limits (0 = unlimited)
MAX_UPLOAD_SIZE_MB=0
MAX_BATCH_SIZE=0
RATE_LIMIT_PER_MIN=0
MAX_USERS=0

# Networking
TRUST_PROXY=true

# Bind mount permissions
PUID=1000
PGID=1000