# ============================================
# Image tags
# ============================================
PANGOLIN_IMAGE_TAG=ee-1.17.1
GERBIL_IMAGE_TAG=latest
TRAEFIK_IMAGE_TAG=v3.6
CROWDSEC_IMAGE_TAG=latest

# ============================================
# Domain
# ============================================
DOMAIN=opendemo.online
DASHBOARD_SUBDOMAIN=pangolin

# ============================================
# Admin / Let's Encrypt
# ============================================
LETSENCRYPT_EMAIL=vitaliisili@yahoo.com
ADMIN_EMAIL=vitaliisili@yahoo.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# Pangolin server secret (openssl rand -hex 32)
# Used for signing sessions / encrypting data
# Generate ONCE, never change it after
# ============================================
PANGOLIN_SERVER_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# ============================================
# CrowdSec
# ============================================
CROWDSEC_COLLECTIONS="crowdsecurity/traefik crowdsecurity/appsec-virtual-patching crowdsecurity/appsec-generic-rules"
# Pre-generated bouncer key (openssl rand -hex 32)
# CrowdSec accepts this on first boot via BOUNCER_KEY_traefik-bouncer env
CROWDSEC_BOUNCER_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32

# ============================================
# Misc
# ============================================
TZ=Europe/Berlin