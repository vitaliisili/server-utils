# ============================================
# Image tags (change to update versions)
# ============================================
PANGOLIN_IMAGE_TAG=ee-1.17.1
GERBIL_IMAGE_TAG=latest
TRAEFIK_IMAGE_TAG=v3.6
CROWDSEC_IMAGE_TAG=latest

# ============================================
# Service hostnames (used as both Docker hostname and container_name)
# ============================================
PANGOLIN_HOST=pangolin
GERBIL_HOST=gerbil
TRAEFIK_HOST=pangolin-traefik
CROWDSEC_HOST=pangolin-crowdsec

# ============================================
# Public-facing ports (Gerbil binds them on host)
# ============================================
PANGOLIN_HTTP_PORT=80
PANGOLIN_HTTPS_PORT=443
PANGOLIN_WG_PORT=51820
PANGOLIN_WG_RELAY_PORT=21820

# ============================================
# Domain configuration
# ============================================
DOMAIN=my-domain.com
DASHBOARD_SUBDOMAIN=pangolin

# ============================================
# Initial admin / Let's Encrypt
# ============================================
LETSENCRYPT_EMAIL=you@example.com
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-strong-password

# ============================================
# CrowdSec
# ============================================
CROWDSEC_GID=1000
CROWDSEC_COLLECTIONS=crowdsecurity/traefik crowdsecurity/appsec-virtual-patching crowdsecurity/appsec-generic-rules
CROWDSEC_ENROLL_TAGS=docker
CROWDSEC_BOUNCER_KEY=<your-generated-key-here>

# ============================================
# Misc
# ============================================
TZ=Europe/Berlin